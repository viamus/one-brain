ONEBRAIN_ENVIRONMENT=local
ONEBRAIN_LOG_LEVEL=INFO
ONEBRAIN_API_KEYS=
ONEBRAIN_PROXY_PORT=80
ONEBRAIN_PROXY_NETWORK=local_proxy
ONEBRAIN_WEB_HOST=onebrain.localhost
ONEBRAIN_API_HOST=api.onebrain.localhost
ONEBRAIN_MCP_HOST=mcp.onebrain.localhost
ONEBRAIN_TRAEFIK_HOST=traefik.localhost
ONEBRAIN_MEMORY_CLASSIFIER_MODEL_PATH=artifacts/memory-classifier.json
ONEBRAIN_DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=67108864
ONEBRAIN_MCP_REQUIRE_API_KEY=true
ONEBRAIN_POSTGRES_VOLUME=onebrain_postgres_data
ONEBRAIN_QDRANT_VOLUME=onebrain_qdrant_storage
ONEBRAIN_JOB_STATUS_VOLUME=onebrain_job_status
ONEBRAIN_ML_ARTIFACTS_VOLUME=onebrain_ml_artifacts

POSTGRES_DB=onebrain
POSTGRES_USER=onebrain
POSTGRES_PASSWORD=onebrain

ONEBRAIN_DATABASE_URL=postgresql+asyncpg://onebrain:onebrain@localhost:5432/onebrain

ONEBRAIN_QDRANT_URL=http://localhost:6333
ONEBRAIN_QDRANT_API_KEY=
ONEBRAIN_QDRANT_COLLECTION=onebrain_memories
ONEBRAIN_VECTOR_SIZE=384

# Use "openai" for production semantic recall, "fastembed" for local semantic
# embeddings, or "hash" for a no-cost local setup.
ONEBRAIN_EMBEDDING_PROVIDER=hash
ONEBRAIN_EMBEDDING_MODEL=text-embedding-3-small
ONEBRAIN_OPENAI_API_KEY=

ONEBRAIN_ENABLE_HEURISTIC_ENTITY_EXTRACTION=false
ONEBRAIN_MAX_CONTEXT_TOKENS=6000
